{
  "name": "quereek",
  "private": true,
  "version": "0.1.0",
  "description": "Learn GraphQL by using it — a Kanban task manager where every action shows you the exact GraphQL operation behind it.",
  "keywords": [
    "graphql",
    "apollo",
    "apollo-server",
    "apollo-client",
    "react",
    "learning",
    "education",
    "kanban"
  ],
  "homepage": "https://github.com/edvardhov/quereek#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edvardhov/quereek.git"
  },
  "bugs": {
    "url": "https://github.com/edvardhov/quereek/issues"
  },
  "author": "Edvard Hovhannisyan",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx server/dev.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@apollo/server": "^5.5.1",
    "@as-integrations/express4": "^1.1.2",
    "@graphql-tools/schema": "^10.0.33",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "graphql": "^16.14.2",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.8",
    "lucide-react": "^1.20.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
